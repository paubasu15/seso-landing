---
const { data } = Astro.props;
const { slides } = data || {};
const firstSlide = slides && slides.length > 0 ? slides[0] : null;
---

{firstSlide && (
  <section
    class="relative py-20 sm:py-28 lg:py-36 px-4 sm:px-6 lg:px-8 overflow-hidden"
    style={firstSlide.imageUrl
      ? `background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('${firstSlide.imageUrl}'); background-size: cover; background-position: center;`
      : `background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));`}
  >
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        {firstSlide.title}
      </h1>
      {firstSlide.subtitle && (
        <p class="text-lg sm:text-xl lg:text-2xl text-white/90 mb-10 max-w-2xl mx-auto">
          {firstSlide.subtitle}
        </p>
      )}
      {firstSlide.ctaText && (
        <a
          href={firstSlide.ctaLink || '#'}
          style="color: var(--color-primary);"
          class="inline-block bg-white font-bold px-8 py-4 rounded-full text-lg shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200"
        >
          {firstSlide.ctaText}
        </a>
      )}
    </div>

    {slides.length > 1 && (
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2">
        {slides.map((_, i) => (
          <span
            class={`block rounded-full transition-all duration-200 ${i === 0 ? 'w-6 h-2.5' : 'w-2.5 h-2.5 opacity-50'} bg-white`}
          ></span>
        ))}
      </div>
    )}
  </section>
)}
