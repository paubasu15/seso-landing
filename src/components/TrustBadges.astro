---
const { data } = Astro.props;
const { items } = data || {};

const iconMap = {
  shield: '🛡️',
  check: '✅',
  star: '⭐',
  lock: '🔒',
  truck: '🚚',
  refresh: '🔄',
  heart: '❤️',
  award: '🏆',
  zap: '⚡',
  clock: '⏰',
};

function getIcon(icon) {
  return iconMap[icon] || icon || '✨';
}
---

{items && items.length > 0 && (
  <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap justify-center gap-4">
        {items.map((badge) => (
          <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-6 py-4">
            <span class="text-2xl">{getIcon(badge.icon)}</span>
            <span class="text-sm font-medium text-gray-700">{badge.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
