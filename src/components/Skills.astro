---
const { data } = Astro.props;
const { title, items } = data || {};
---

{items && items.length > 0 && (
  <section class="py-16 sm:py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      {title && (
        <h2
          style="color: var(--color-primary);"
          class="text-3xl sm:text-4xl font-bold text-center mb-12"
        >
          {title}
        </h2>
      )}
      <div class="max-w-2xl mx-auto flex flex-col gap-6">
        {items.map((item) => (
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="font-semibold text-sm" style="color: var(--color-text);">{item.name}</span>
              <span class="text-sm text-gray-500">{item.level}</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-3">
              <div
                class="h-3 rounded-full transition-all duration-500"
                style={`background-color: var(--color-primary); width: ${item.level}%;`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
