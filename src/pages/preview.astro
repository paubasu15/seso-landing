---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import { getTenantConfig } from '../lib/api.js';
import { getTenantSlug } from '../lib/tenant.js';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');

const tenant = getTenantSlug(Astro.request);
const config = await getTenantConfig(tenant, { draft: true });

const componentMap = {
  header: Header,
  hero: Hero,
  features: Features,
  testimonials: Testimonials,
  pricing: Pricing,
  footer: Footer,
};

const visibleComponents = (config.components || [])
  .filter(c => c.visible)
  .sort((a, b) => a.order - b.order);
---

<Layout config={config}>
  {visibleComponents.map(comp => {
    const Component = componentMap[comp.type];
    return Component ? <Component data={comp.data} config={config} /> : null;
  })}
</Layout>
