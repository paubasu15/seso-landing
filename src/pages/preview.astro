---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Gallery from '../components/Gallery.astro';
import Skills from '../components/Skills.astro';
import ContactForm from '../components/ContactForm.astro';
import HeroSlider from '../components/HeroSlider.astro';
import ProductGrid from '../components/ProductGrid.astro';
import TrustBadges from '../components/TrustBadges.astro';
import { getTenantConfig } from '../lib/api.js';
import { getTenantSlug } from '../lib/tenant.js';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
Astro.response.headers.set('Pragma', 'no-cache');

const tenant = getTenantSlug(Astro.request);
const config = await getTenantConfig(tenant, { draft: true });

const componentMap = {
  header: Header,
  hero: Hero,
  features: Features,
  testimonials: Testimonials,
  pricing: Pricing,
  footer: Footer,
  'cta-banner': CtaBanner,
  gallery: Gallery,
  skills: Skills,
  'contact-form': ContactForm,
  'hero-slider': HeroSlider,
  'product-grid': ProductGrid,
  'trust-badges': TrustBadges,
};

const visibleComponents = (config.components || [])
  .filter(c => c.visible)
  .sort((a, b) => a.order - b.order);
---

<Layout config={config}>
  {visibleComponents.map(comp => {
    const Component = componentMap[comp.type];
    return Component ? <Component data={comp.data} config={config} /> : null;
  })}
</Layout>
